# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# === Telegram ===
# Token from @BotFather. The bot must be an ADMIN of your supergroup with
# "Manage Topics" permission, and you MUST disable its privacy mode
# (@BotFather -> /setprivacy -> Disable) so it can read messages in topics.
TELEGRAM_BOT_TOKEN=

# The supergroup (with Topics enabled) this bot operates in.
# Leave blank on first run; the bot logs the chat_id of the group it's added to.
TELEGRAM_CHAT_ID=

# Comma-separated Telegram user IDs allowed to command the bot (from @userinfobot).
# REQUIRED and enforced: the bot ignores everyone not listed here.
TELEGRAM_ALLOWED_USER_IDS=

# Display name / persona for the bot in its own messages. Optional.
BOT_NAME=Session Manager

# === Claude sessions ===
# bypassPermissions is required for headless operation (no TTY to answer prompts).
# Alternatives: acceptEdits | default (will stall on prompts — not recommended).
CLAUDE_PERMISSION_MODE=bypassPermissions

# Base directory that bare `/new <name>` paths resolve against (absolute paths to
# /new are used as-is). Blank => your home dir. In Docker this is set to /workspace
# by docker-compose, so leave it blank here unless running locally.
PROJECTS_ROOT=

# Optional: path to the `claude` executable if not on PATH
# (install: npm install -g @anthropic-ai/claude-code).
CLAUDE_CLI_PATH=

# Optional: default model (blank = account default). e.g. claude-opus-4-8
CLAUDE_MODEL=

# Optional: hard ceiling on assistant turns per user message.
CLAUDE_MAX_TURNS=

# Optional: extra text appended to each session's system prompt. Leave UNSET to use
# the built-in environment-awareness note; set to empty to disable it entirely.
# SESSION_SYSTEM_APPEND=

# Where session state (topic<->session_id map) is persisted. In Docker this is set
# to /data by docker-compose.
STATE_DIR=state

# === Docker host paths (used only by docker-compose variable substitution) ===
# HOST_DOCUMENTS: the host folder shared into the container as /workspace (your repos).
# HOST_CLAUDE_DIR: your Claude login/session dir, shared as /root/.claude for auth.
# Use forward slashes on all platforms, e.g.:
#   Linux/macOS:  HOST_DOCUMENTS=/home/you/projects     HOST_CLAUDE_DIR=/home/you/.claude
#   Windows:      HOST_DOCUMENTS=C:/Users/You/Documents HOST_CLAUDE_DIR=C:/Users/You/.claude
HOST_DOCUMENTS=
HOST_CLAUDE_DIR=
