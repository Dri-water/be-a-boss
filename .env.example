# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# === Telegram surface (only for the Telegram bot) ===
# None of this section is needed for the browser / VS Code surface — for that,
# just run `python -m beaboss.web` (it prints a one-time connect URL with a token;
# see the Web surface section below).
#
# Token from @BotFather. The bot must be an ADMIN of your supergroup with
# "Manage Topics" permission. (Admins receive all group messages — privacy
# mode does not need to be touched.)
TELEGRAM_BOT_TOKEN=

# The supergroup (with Topics enabled) this bot operates in.
# Leave blank on first run; the bot logs the chat_id of the group it's added to.
TELEGRAM_CHAT_ID=

# Comma-separated Telegram user IDs allowed to command the bot. The bot ignores
# everyone not listed. Leave blank on the very first run: the bot starts in setup
# mode (only /whoami works), so you DM it /whoami to learn your id, put it here,
# and restart. No third-party bot needed.
TELEGRAM_ALLOWED_USER_IDS=

# Display name / persona for the bot in its own messages. Optional.
BOT_NAME=Orchestrator

# === Web / VS Code surface (only for `python -m beaboss.web`) ===
# Access token required on every WebSocket connection (?token=…). Leave blank to
# have the server mint a fresh one each run and print the connect URL; set it to
# pin a stable token (e.g. so a saved VS Code `beaboss.wsUrl` keeps working).
WEB_TOKEN=

# The server binds to localhost only and refuses a public bind. Set to 1 ONLY if
# you understand the risk and are fronting it with your own auth (e.g. a reverse
# proxy). Prefer an SSH tunnel to reach a remote box instead.
WEB_ALLOW_INSECURE_BIND=

# === Agent sessions ===
# Which agent runtime workers run on: "claude" (default, Claude Code SDK) or
# "codex" (OpenAI's Codex CLI, `codex exec`).
BEABOSS_BACKEND=

# The knobs below are backend-NEUTRAL (AGENT_*). To tune just one backend, set a
# harness-specific override instead — CLAUDE_* or CODEX_* — which wins only when
# that backend is active (e.g. CODEX_MODEL overrides AGENT_MODEL under Codex).

# Auto-approval mode. bypassPermissions is required for headless operation (no TTY
# to answer prompts). Alternatives: acceptEdits | default (will stall — avoid).
AGENT_PERMISSION_MODE=bypassPermissions

# Optional: default model (blank = the backend's account default). e.g. claude-opus-4-8
AGENT_MODEL=

# Optional: hard ceiling on assistant turns per user message.
AGENT_MAX_TURNS=

# Optional: path to the backend CLI if not on PATH
# (Claude Code: npm install -g @anthropic-ai/claude-code).
AGENT_CLI_PATH=

# Base directory that bare `/new <name>` paths resolve against (absolute paths to
# /new are used as-is). Blank => your home dir. In Docker this is set to /workspace
# by docker-compose, so leave it blank here unless running locally.
PROJECTS_ROOT=

# Optional: a GitHub token (PAT) that turns on PR-based delivery. With it, the
# orchestrator can open a pull request for a finished worker (`gh pr create`);
# without it, delivery falls back to a local merge on your approval. Leave blank
# unless you want workers' finished branches to land as PRs.
GH_TOKEN=

# Optional: extra text appended to each session's system prompt. Leave UNSET to use
# the built-in environment-awareness note; set to empty to disable it entirely.
# SESSION_SYSTEM_APPEND=

# Where session state (topic<->session_id map) is persisted. In Docker this is set
# to /data by docker-compose.
STATE_DIR=state

# === Docker host paths (used only by docker-compose variable substitution) ===
# HOST_DOCUMENTS: the host folder shared into the container as /workspace (your repos).
# HOST_CLAUDE_DIR: your Claude login/session dir, shared as /root/.claude for auth.
# Use forward slashes on all platforms, e.g.:
#   Linux/macOS:  HOST_DOCUMENTS=/home/you/projects     HOST_CLAUDE_DIR=/home/you/.claude
#   Windows:      HOST_DOCUMENTS=C:/Users/You/Documents HOST_CLAUDE_DIR=C:/Users/You/.claude
HOST_DOCUMENTS=
HOST_CLAUDE_DIR=
